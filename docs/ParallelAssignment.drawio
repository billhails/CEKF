        <mxCell id="rYJ3PU1JVw-uveJOSQzk-127" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="$$r_t$$" vertex="1">
