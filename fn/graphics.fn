fn begin_shader_mode(shader) {
    gfx_begin_shader_mode(shader)
}

fn end_shader_mode() { gfx_end_shader_mode() }

fn set_shader_int(shader, name, value) {
    gfx_set_shader_int(shader, name, value)
}

fn set_shader_float(shader, name, value) {
    gfx_set_shader_float(shader, name, value)
}

fn set_shader_vec2(shader, name, point(x, y)) {
    gfx_set_shader_vec2(shader, name, x, y)
}

fn set_shader_vec3(shader, name, vec3(x, y, z)) {
    gfx_set_shader_vec3(shader, name, x, y, z)
}

fn with_shader_mode(shader, draw_fn) {
    assert(gfx_begin_shader_mode(shader));
    {
    let result = draw_fn();
    in
        assert(gfx_end_shader_mode());
        result
    }
}

fn begin_mode_2d(point(target_x, target_y), point(offset_x, offset_y), rotation, zoom) {
    gfx_begin_mode_2d(target_x, target_y, offset_x, offset_y, rotation, zoom)
}

fn end_mode_2d() { gfx_end_mode_2d() }

fn with_camera2d(point(target_x, target_y), point(offset_x, offset_y), rotation, zoom, draw_fn) {
    assert(gfx_begin_mode_2d(target_x, target_y, offset_x, offset_y, rotation, zoom));
    {
    let result = draw_fn();
    in
        assert(gfx_end_mode_2d());
        result
    }
}

fn projection_perspective() { 0 }
fn projection_orthographic() { 1 }

fn begin_mode_3d(
    vec3(pos_x, pos_y, pos_z),
    vec3(target_x, target_y, target_z),
    vec3(up_x, up_y, up_z),
    fovy,
    projection
) {
    gfx_begin_mode_3d(
        pos_x,
        pos_y,
        pos_z,
        target_x,
        target_y,
        target_z,
        up_x,
        up_y,
        up_z,
        fovy,
        projection
    )
}

fn end_mode_3d() { gfx_end_mode_3d() }

fn with_camera3d(position, target, up, fovy, projection, draw_fn) {
    assert(begin_mode_3d(position, target, up, fovy, projection));
    {
    let result = draw_fn();
    in
        assert(end_mode_3d());
        result
    }
}

