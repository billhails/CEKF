fn audio_open() { gfx_audio_open() }

fn audio_close() { gfx_audio_close() }

fn with_audio(handler) {
    if (gfx_audio_open()) {
        let result = just(handler());
        in
            gfx_audio_close();
            result
    } else {
        puts("audio error: failed to open audio device");
        putc('\n');
        nothing
    }
}

