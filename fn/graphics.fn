namespace

typedef Color { rgba(number, number, number, number) }
typedef Point { point(number, number) }
typedef Vec3 { vec3(number, number, number) }
typedef Size { extent(number, number) }
typedef Rect { rect(number, number, number, number) }

fn rgb(r, g, b) {
    rgba(r, g, b, 255)
}

fn black() { rgba(0, 0, 0, 255) }
fn white() { rgba(255, 255, 255, 255) }
fn red() { rgba(255, 0, 0, 255) }
fn green() { rgba(0, 255, 0, 255) }
fn blue() { rgba(0, 0, 255, 255) }

fn with_window_size(extent(width, height), title, handler) {
    with_window(width, height, title, handler)
}

fn load_render_texture_size(extent(width, height)) {
    load_render_texture(width, height)
}

fn with_render_texture_size(extent(width, height), handler) {
    with_render_texture(width, height, handler)
}

fn point_x(point(x, _)) { x }
fn point_y(point(_, y)) { y }
fn translate(point(x, y), dx, dy) { point(x + dx, y + dy) }
fn vec3_x(vec3(x, _, _)) { x }
fn vec3_y(vec3(_, y, _)) { y }
fn vec3_z(vec3(_, _, z)) { z }

fn mat2d_identity() {
    gfx_mat2d_identity()
}

fn mat2d_translate(mat, dx, dy) {
    gfx_mat2d_translate(mat, dx, dy)
}

fn mat2d_rotate(mat, degrees) {
    gfx_mat2d_rotate(mat, degrees)
}

fn mat2d_scale(mat, sx, sy) {
    gfx_mat2d_scale(mat, sx, sy)
}

fn mat2d_compose(left, right) {
    gfx_mat2d_compose(left, right)
}

fn mat2d_apply_x(mat, x, y) {
    gfx_mat2d_apply_x(mat, x, y)
}

fn mat2d_apply_y(mat, x, y) {
    gfx_mat2d_apply_y(mat, x, y)
}

fn mat2d_apply_point(mat, point(x, y)) {
    point(mat2d_apply_x(mat, x, y), mat2d_apply_y(mat, x, y))
}

fn make_transform3d(pos, rot, scale) {
    gfx_transform3d(
        vec3_x(pos), vec3_y(pos), vec3_z(pos),
        vec3_x(rot), vec3_y(rot), vec3_z(rot),
        vec3_x(scale), vec3_y(scale), vec3_z(scale)
    )
}

fn transform3d_position(raw) {
    vec3(
        gfx_transform3d_position_x(raw),
        gfx_transform3d_position_y(raw),
        gfx_transform3d_position_z(raw)
    )
}

fn transform3d_rotation(raw) {
    vec3(
        gfx_transform3d_rotation_x(raw),
        gfx_transform3d_rotation_y(raw),
        gfx_transform3d_rotation_z(raw)
    )
}

fn transform3d_scale(raw) {
    vec3(
        gfx_transform3d_scale_x(raw),
        gfx_transform3d_scale_y(raw),
        gfx_transform3d_scale_z(raw)
    )
}

fn with_window(width, height, title, handler) {
    switch (gfx_open(width, height, title)) {
        (success(_)) {
            let data = just(handler());
            in
                gfx_close();
                data
        }
        (failure(errmsg)) {
            puts("graphics error: ");
            puts(errmsg);
            putc('\n');
            nothing
        }
    }
}

fn set_target_fps(fps) {
    gfx_set_target_fps(fps)
}

fn should_close() {
    gfx_should_close()
}

fn clear(rgba(r, g, b, a)) {
    gfx_clear(r, g, b, a)
}

fn fill_rect(x, y, w, h, rgba(r, g, b, a)) {
    gfx_fill_rect(x, y, w, h, r, g, b, a)
}

fn draw_text(text, x, y, size, rgba(r, g, b, a)) {
    gfx_draw_text(text, x, y, size, r, g, b, a)
}

fn frame(background, draw) {
    assert(gfx_begin_frame());
    clear(background);
    {
    let result = draw();
    in
        assert(gfx_end_frame());
        result
    }
}

fn loop(background, draw) {
    if (should_close()) {
        true
    } else {
        frame(background, draw);
        loop(background, draw)
    }
}

fn run(width, height, title, fps, background, draw) {
    with_window(width, height, title, fn () {
        assert(set_target_fps(fps));
        loop(background, draw)
    })
}

// --- input queries ---

fn key_held(k) { gfx_is_key_down(k) }
fn key_pressed(k) { gfx_is_key_pressed(k) }
fn key_released(k) { gfx_is_key_released(k) }
fn mouse_held(btn) { gfx_is_mouse_down(btn) }
fn mouse_pressed(btn) { gfx_is_mouse_pressed(btn) }
fn mouse_released(btn) { gfx_is_mouse_released(btn) }
fn mouse_x() { gfx_mouse_x() }
fn mouse_y() { gfx_mouse_y() }
fn mouse_delta_x() { gfx_mouse_delta_x() }
fn mouse_delta_y() { gfx_mouse_delta_y() }
fn mouse_wheel() { gfx_mouse_wheel() }
fn disable_cursor() { gfx_disable_cursor() }
fn enable_cursor() { gfx_enable_cursor() }
fn hide_cursor() { gfx_hide_cursor() }
fn show_cursor() { gfx_show_cursor() }
fn screen_width() { gfx_screen_width() }
fn screen_height() { gfx_screen_height() }
fn frame_time_ms() { gfx_frame_time_ms() }

