let
    link "gfxutils.fn" as gfx;
    width = 800;
    height = 600;
in {
    let
        fn animate(x) {
            if (gfx.should_close()) {
                true
            } else {
                let
                    next = if (x > width) { 0 } else { x + 2 };
                in
                    gfx.frame(gfx.black(), fn () {
                        gfx.draw_text("Hello!", x, height/3, 24, gfx.white())
                    });
                    animate(next)
            }
        }
    in
        gfx.with_window(width, height, "Moving Text", fn () {
            assert(gfx.set_target_fps(60));
            animate(0)
        })
}