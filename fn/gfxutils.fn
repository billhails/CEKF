    vec3(target_x, target_y, target_z),
    vec3(up_x, up_y, up_z),
    left,
    right,
    bottom,
    top,
    near,
    far
) {
    gfx_set_shader_light_vp_ortho_vp(
        shader,
        name,
        light_pos_x,
        light_pos_y,
        light_pos_z,
        target_x,
        target_y,
        target_z,
        up_x,
        up_y,
        up_z,
        left,
        right,
        bottom,
        top,
        near,
        far
    )
}

fn set_shader_light_vp_ortho_pv(
    shader,
    name,
    vec3(light_pos_x, light_pos_y, light_pos_z),
    vec3(target_x, target_y, target_z),
    vec3(up_x, up_y, up_z),
    left,
    right,
    bottom,
    top,
    near,
    far
) {
    gfx_set_shader_light_vp_ortho_pv(
        shader,
        name,
        light_pos_x,
        light_pos_y,
        light_pos_z,
        target_x,
        target_y,
        target_z,
        up_x,
        up_y,
        up_z,
        left,
        right,
        bottom,
        top,
        near,
        far
    )
}

fn with_shader_mode(shader, draw_fn) {
    assert(gfx_begin_shader_mode(shader));
    {
    let result = draw_fn();
    in
        assert(gfx_end_shader_mode());
        result
    }
}

fn begin_mode_2d(point(target_x, target_y), point(offset_x, offset_y), rotation, zoom) {
    gfx_begin_mode_2d(target_x, target_y, offset_x, offset_y, rotation, zoom)
}

fn end_mode_2d() { gfx_end_mode_2d() }

fn with_camera2d(point(target_x, target_y), point(offset_x, offset_y), rotation, zoom, draw_fn) {
    assert(gfx_begin_mode_2d(target_x, target_y, offset_x, offset_y, rotation, zoom));
    {
    let result = draw_fn();
    in
        assert(gfx_end_mode_2d());
        result
    }
}

fn projection_perspective() { 0 }
fn projection_orthographic() { 1 }

fn begin_mode_3d(
    vec3(pos_x, pos_y, pos_z),
    vec3(target_x, target_y, target_z),
    vec3(up_x, up_y, up_z),
    fovy,
    projection
) {
    gfx_begin_mode_3d(
        pos_x,
        pos_y,
        pos_z,
        target_x,
        target_y,
        target_z,
        up_x,
        up_y,
        up_z,
        fovy,
        projection
    )
}

fn end_mode_3d() { gfx_end_mode_3d() }

fn with_camera3d(position, target, up, fovy, projection, draw_fn) {
    assert(begin_mode_3d(position, target, up, fovy, projection));
    {
    let result = draw_fn();
    in
        assert(end_mode_3d());
        result
    }
}

fn draw_cube(vec3(center_x, center_y, center_z), vec3(size_x, size_y, size_z), rgba(r, g, b, a)) {
    gfx_draw_cube(center_x, center_y, center_z, size_x, size_y, size_z, r, g, b, a)
}

fn draw_cube_wires(vec3(center_x, center_y, center_z), vec3(size_x, size_y, size_z), rgba(r, g, b, a)) {
    gfx_draw_cube_wires(center_x, center_y, center_z, size_x, size_y, size_z, r, g, b, a)
}

fn draw_grid(slices, spacing) {
    gfx_draw_grid(slices, spacing)
}

fn draw_sphere(vec3(center_x, center_y, center_z), radius, rgba(r, g, b, a)) {
    gfx_draw_sphere(center_x, center_y, center_z, radius, r, g, b, a)
}

fn draw_sphere_wires(vec3(center_x, center_y, center_z), radius, rings, slices, rgba(r, g, b, a)) {
    gfx_draw_sphere_wires(center_x, center_y, center_z, radius, rings, slices, r, g, b, a)
}

fn draw_cylinder(vec3(pos_x, pos_y, pos_z), radius_top, radius_bottom, height, slices, rgba(r, g, b, a)) {
    gfx_draw_cylinder(pos_x, pos_y, pos_z, radius_top, radius_bottom, height, slices, r, g, b, a)
}

fn draw_cylinder_wires(vec3(pos_x, pos_y, pos_z), radius_top, radius_bottom, height, slices, rgba(r, g, b, a)) {
    gfx_draw_cylinder_wires(pos_x, pos_y, pos_z, radius_top, radius_bottom, height, slices, r, g, b, a)
}

fn draw_plane(vec3(center_x, center_y, center_z), vec3(size_x, _, size_z), rgba(r, g, b, a)) {
    gfx_draw_plane(center_x, center_y, center_z, size_x, size_z, r, g, b, a)
}

fn draw_line_3d(vec3(start_x, start_y, start_z), vec3(end_x, end_y, end_z), rgba(r, g, b, a)) {
    gfx_draw_line_3d(start_x, start_y, start_z, end_x, end_y, end_z, r, g, b, a)
}

fn load_model(path) {
    gfx_load_model(path)
}

fn unload_model(model) { gfx_unload_model(model) }

fn set_model_shader(model, shader) {
    gfx_set_model_shader(model, shader)
}

fn material_count(model) {
    gfx_model_material_count(model)
}

fn set_material_shader(model, material_index, shader) {
    gfx_set_material_shader(model, material_index, shader)
}

fn set_material_map(model, material_index, map_kind, texture) {
    gfx_set_material_map(model, material_index, map_kind, texture)
}

fn draw_model_at(model, vec3(pos_x, pos_y, pos_z), scale, rgba(r, g, b, a)) {
    gfx_draw_model(model, pos_x, pos_y, pos_z, scale, r, g, b, a)
}

fn draw_model_wires_at(model, vec3(pos_x, pos_y, pos_z), scale, rgba(r, g, b, a)) {
    gfx_draw_model_wires(model, pos_x, pos_y, pos_z, scale, r, g, b, a)
}

fn with_model(path, handler) {
    switch (gfx_load_model(path)) {
        (success(model)) {
            let result = just(handler(model));
            in
                gfx_unload_model(model);
                result
        }
        (failure(msg)) {
            puts("model load error: ");
            puts(msg);
            putc('\n');
            nothing
        }
    }
}

fn audio_open() { gfx_audio_open() }

fn audio_close() { gfx_audio_close() }

fn with_audio(handler) {
    if (gfx_audio_open()) {
        let result = just(handler());
        in
            gfx_audio_close();
            result
    } else {
        puts("audio error: failed to open audio device");
        putc('\n');
        nothing
    }
}

fn load_sound(path) {
    gfx_load_sound(path)
}

fn unload_sound(sound) { gfx_unload_sound(sound) }

fn play_sound(sound) { gfx_play_sound(sound) }

fn stop_sound(sound) { gfx_stop_sound(sound) }

fn is_sound_playing(sound) { gfx_is_sound_playing(sound) }

fn set_sound_volume(sound, percent) {
    gfx_set_sound_volume(sound, percent)
}

fn with_sound(path, handler) {
    switch (gfx_load_sound(path)) {
        (success(sound)) {
            let result = just(handler(sound));
            in
                gfx_unload_sound(sound);
                result
        }
        (failure(msg)) {
            puts("sound load error: ");
            puts(msg);
            putc('\n');
            nothing
        }
    }
}

