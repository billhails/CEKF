let
    link "graphics.fn" as gfx;

    fn loop_frames(n, shader, tex0, tex1) {
        if (n <= 0) { true }
        else {
            let blend = n / 8;
            in
            {
                gfx.frame(gfx.rgb(18, 20, 30), fn () {
                    gfx.with_shader_mode(shader, fn () {
                        assert(gfx.set_shader_sampler(shader, "uTex0", tex0, gfx.sampler_unit0()));
                        assert(gfx.set_shader_sampler(shader, "uTex1", tex1, gfx.sampler_unit1()));
                        assert(gfx.set_shader_float(shader, "uBlend", blend));
                        assert(gfx.draw_texture_at(tex0, gfx.point(24, 24), gfx.white()))
                    })
                });

                loop_frames(n - 1, shader, tex0, tex1)
            }
        }
    }
in
    if (gfx.enabled()) {
        {
            gfx.with_window_size(gfx.extent(360, 240), "Test Gfx Sampler Smoke", fn () {
                gfx.with_shader("assets/shaders/basic.vs", "assets/shaders/sampler_blend.fs", fn (shader) {
                    gfx.with_texture("docs/CEKF.png", fn (tex0) {
                        gfx.with_texture("docs/CEKF2.png", fn (tex1) {
                            assert(gfx.set_shader_sampler(shader, "uTex0", tex0, 99) == false);
                            loop_frames(4, shader, tex0, tex1)
                        })
                    })
                })
            });
            true
        }
    } else {
        true
    }
