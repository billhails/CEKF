let
    link "graphics.fn" as gfx;
in
    if (gfx.enabled()) {
        {
            gfx.with_window_size(gfx.extent(360, 260), "Test Gfx RT Sampler Smoke", fn () {
                gfx.with_shader("assets/shaders/basic.vs", "assets/shaders/sampler_blend.fs", fn (shader) {
                    gfx.with_texture("docs/CEKF2.png", fn (tex) {
                        gfx.with_render_texture_size(gfx.extent(160, 120), fn (rt) {
                            gfx.render_to_texture(rt, gfx.rgb(12, 16, 26), fn () {
                                assert(gfx.fill_rect_from(gfx.rect(12, 16, 128, 44), gfx.rgb(220, 130, 110)));
                                assert(gfx.draw_texture_at(tex, gfx.point(18, 58), gfx.white()))
                            });

                            assert(gfx.set_shader_render_texture_sampler(
                                shader,
                                "uTex0",
                                rt,
                                9,
                                gfx.sampler_attachment_color()
                            ) == false);

                            gfx.frame(gfx.rgb(20, 24, 36), fn () {
                                gfx.with_shader_mode(shader, fn () {
                                    assert(gfx.set_shader_render_texture_sampler(
                                        shader,
                                        "uTex0",
                                        rt,
                                        gfx.sampler_unit0(),
                                        gfx.sampler_attachment_color()
                                    ));
                                    assert(gfx.set_shader_sampler(shader, "uTex1", tex, gfx.sampler_unit1()));
                                    assert(gfx.set_shader_float(shader, "uBlend", 0.5));
                                    assert(gfx.draw_texture_at(tex, gfx.point(40, 70), gfx.white()))
                                })
                            })
                        })
                    })
                })
            });
            true
        }
    } else {
        true
    }
