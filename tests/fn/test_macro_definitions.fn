let
    syntax internalTime: Expr ::= "time" "(" expr: Expr ")" {
        expr
    };

    syntax internalEcho: Expr ::= "echo" message: String {
        message
    };

    syntax chooseValue(value) ::= "with" "skip" ignored: Expr {
        value
    }
    | replacement: Expr {
        replacement
    };

    syntax internalGrab: Expr ::= "grab" "(" value: Expr ")" result: Syntax(chooseValue(value)) {
        result
    };

    syntax unless ::= "unless" "(" cond: Expr ")" consequent: Nest "else" alternative: Nest {
        cond
    };

    syntax annotate ::= "annotate" name: Name ":" annotation: Type "=" value: Expr {
        value
    };
in
    assert(42 == time(42));
    assert("hello" == echo "hello");
    assert(42 == grab(42) with skip 0);
    assert(7 == grab(42) with 7)